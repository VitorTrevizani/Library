    "/user/register": {
      "post": {
        "tags": [
          "Users"
        ],
        "description": "Recebe nome, email e senha e salva no banco de dados",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Vitão"
                },
                "email": {
                  "type": "string",
                  "example": "vitao@email.com"
                },
                "password": {
                  "type": "string",
                  "example": "APItest"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "500": {
            "description": "Internal Server Error"
          },
          "409": {
            "description": "O usuário informado já existe"
          },
          "422": {
            "description": "Unprocessable Entity"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },


